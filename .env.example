# Local development — copy to .env and fill in values.
DATABASE_URL="mysql://user:password@host:port/database"
ADMIN_PASSWORD="your-admin-password"
CRON_SECRET="generate-with: openssl rand -hex 24"
ADMIN_SESSION_SECRET="generate-with: openssl rand -hex 32 (min 32 chars)"

# Vercel Blob — 用于 Vercel 部署环境下的图片上传持久化
# 在 Vercel 项目设置中创建 Blob Store 后，会自动生成此 token
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

SITE_URL="http://localhost:3000"

# Vercel (Project → Settings → Environment Variables → Production):
# - DATABASE_URL: Railway MySQL public URL. Append serverless params:
#   ?connection_limit=1&connect_timeout=10
#   Example: mysql://user:pass@host.railway.app:port/railway?connection_limit=1&connect_timeout=10
# - ADMIN_PASSWORD: same as local
# - ADMIN_SESSION_SECRET: same as local (min 32 chars)
# - CRON_SECRET: same as local (used by vercel.json cron to authenticate)
# - SITE_URL: https://your-app.vercel.app
# After saving variables, trigger a Redeploy so they take effect.
