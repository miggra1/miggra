generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum NoteStatus {
  DRAFT
  PUBLISHED
}

enum ContentSection {
  NOW
  WISH
  READING
  INSPIRATION
  TIMELINE
}

model Note {
  id        String     @id @default(cuid())
  title     String
  text      String     @db.Text
  tag       String     @default("随想")
  status    NoteStatus @default(PUBLISHED)
  pinned    Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("notes")
  @@index([status, createdAt])
}

model ContentItem {
  id        String         @id @default(cuid())
  section   ContentSection
  title     String
  detail    String         @db.Text
  meta      String?
  status    String?
  order     Int            @default(0)
  active    Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("content_items")
  @@index([section, active, order])
}
