generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum NoteStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
}

enum ContentSection {
  NOW
  WISH
  READING
  INSPIRATION
  TIMELINE
}

enum GuestbookStatus {
  PENDING
  PUBLISHED
  HIDDEN
}

enum TimelineKind {
  PERSONAL
  SITE
}

model Note {
  id         String     @id @default(cuid())
  title      String
  text       String     @db.Text
  tag        String     @default("随想")
  status     NoteStatus @default(PUBLISHED)
  pinned     Boolean    @default(false)
  coverImage  String?    // 封面图 URL
  scheduledAt DateTime?  // 定时发布时间
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("notes")
  @@index([status, createdAt])
  @@index([status, scheduledAt])
}

model ContentItem {
  id        String         @id @default(cuid())
  section   ContentSection
  title     String
  detail    String         @db.Text
  meta      String?
  status    String?
  order     Int            @default(0)
  active    Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("content_items")
  @@index([section, active, order])
}

model GuestbookEntry {
  id        String           @id @default(cuid())
  name      String           @default("匿名")
  message   String           @db.Text
  status    GuestbookStatus   @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@map("guestbook_entries")
  @@index([status, createdAt])
}

model HomepageModule {
  id        String   @id @default(cuid())
  key       String   @unique
  title     String
  enabled   Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("homepage_modules")
  @@index([enabled, order])
}

model TimelineMilestone {
  id        String       @id @default(cuid())
  year      String
  kind      TimelineKind @default(PERSONAL)
  title     String
  detail    String       @db.Text
  order     Int          @default(0)
  active    Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("timeline_milestones")
  @@index([kind, active, order])
}

model Page {
  id        String     @id @default(cuid())
  slug      String     @unique
  title     String
  content   String     @db.Text
  status    NoteStatus @default(DRAFT)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("pages")
  @@index([slug, status])
}
